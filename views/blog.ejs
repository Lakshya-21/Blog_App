<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head")  %>
    <title>Blog</title>
</head>
<body>
    <%- include("./partials/nav")  %>



    <div class = "container mt-4">
        <h1><%= blog.title %></h1>
        <button id="summarizeBtn" class="btn btn-primary mt-3">
    ✨ Summarize with AI
    </button>
        <div id="summaryContainer" class="mt-3"></div>
        <img src="<%= blog.coverImageURL %>" alt="coverImage" width="700px" height = "400px">
        <pre class = "mt-3"><%= blog.body %></pre>
    </div>

    <div class = "container mt-4">
        <img src="<%= blog.createdBy.profileImageUrl %>" alt="profileImage" width="50px"> <%= blog.createdBy.fullName %>
        <% if (user && user._id.toString() === blog.createdBy._id.toString()) { %>
            <% if (user && user._id.toString() === blog.createdBy._id.toString()) { %>
                <a href="/blog/edit/<%= blog._id %>" class="btn btn-warning">
                    Edit Blog
                </a>
            <% } %>
            <form action="/blog/delete/<%= blog._id %>" method="POST" class="mt-3">
                <button
                    class="btn btn-danger"
                    onclick="return confirm('Are you sure you want to delete this blog?')">
                    Delete Blog
                </button>
            </form>
        <%} %>
    </div>

    <div class = "container mt-3">
        <h1>Comments (<%= comments.length %>)</h1>
        <% if (locals.user) { %>
            <form action="/blog/comment/<%= blog._id %>" method="post">
            <div class="mb-3">
                <input type="text" class="form-control" name = "content"  placeholder="Enter your Comment">
            </div>
            <button type="submit" class="btn btn-sm btn-primary">Add</button>
            </form>
        <% } %>
         <div class = "mt-3">
                <% comments.forEach(comment => { %>
                    <div>
                        <img src="<%= comment.createdBy.profileImageUrl %>" alt="profileImage" width="50px"> <%= comment.createdBy.fullName %>
                        <pre> <%= comment.content %></pre>

                    </div>
                <% }) %>

            </div>

    </div>

    

    <%- include("./partials/scripts")  %>


    <script>
    const btn = document.getElementById("summarizeBtn");
    const summaryContainer = document.getElementById("summaryContainer");

    btn.addEventListener("click", async () => {

        btn.disabled = true;
        btn.innerText = "Generating...";

        const response = await fetch("/blog/<%= blog._id %>/summarize", {
            method: "POST",
        });

        const data = await response.json();

        summaryContainer.innerHTML = `
            <h4>✨ AI Summary</h4>
            <pre>${data.summary}</pre>
        `;

        btn.innerText = "Summary Generated";
    });
    </script>
</body>
</html>